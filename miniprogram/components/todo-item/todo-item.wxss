/* 待办条目组件样式 */

/* 已完成项整体变灰暗 */
.todo_item {
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.todo_item.completed {
  opacity: 0.6;
}

.todo_swipe {
  position: relative;
  overflow: hidden;
}

.todo_content {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  background: #fff;
  transition: transform 0.2s ease;
  position: relative;
  z-index: 2;
}

.todo_delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: #E74C3C;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  z-index: 1;
}

/* 勾选框 */
.todo_check {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.check_box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #DDD;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check_box.checked {
  border-color: #6BCB77;
  background: #6BCB77;
}

.check_box.checked.priority_high {
  border-color: #E74C3C;
  background: #E74C3C;
}

.check_box.checked.priority_medium {
  border-color: #F39C12;
  background: #F39C12;
}

.check_box.checked.priority_low {
  border-color: #6BCB77;
  background: #6BCB77;
}

.check_icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

/* 内容 */
.todo_info {
  flex: 1;
  min-width: 0;
}

.todo_title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
  word-break: break-all;
}

.todo_title.line_through {
  text-decoration: line-through;
  color: #BBB;
}

.todo_meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.priority_tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.priority_tag.priority_high {
  background: #FDEDEC;
  color: #E74C3C;
}

.priority_tag.priority_medium {
  background: #FEF5E7;
  color: #F39C12;
}

.priority_tag.priority_low {
  background: #E8F8F5;
  color: #6BCB77;
}

.todo_date {
  font-size: 22rpx;
  color: #BBB;
}
