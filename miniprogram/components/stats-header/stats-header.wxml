<!-- 统计头部组件 — 展示待办事项总数、进行中、已完成数量 -->
<view class="header">
  <view class="header_title">我的待办</view>
  <view class="header_stats">
    <view class="stat_item">
      <text class="stat_num">{{stats.total}}</text>
      <text class="stat_label">全部</text>
    </view>
    <view class="stat_item">
      <text class="stat_num active">{{stats.active}}</text>
      <text class="stat_label">进行中</text>
    </view>
    <view class="stat_item">
      <text class="stat_num done">{{stats.completed}}</text>
      <text class="stat_label">已完成</text>
    </view>
  </view>
</view>
