/* pages/index/index.wxss */
/* 页面级样式 — 组件专属样式已移入各组件的 wxss 文件中 */

page {
  background: #F7F8FA;
  padding-bottom: 160rpx;
}

/* ===== 搜索栏 ===== */
.search_bar {
  display: flex;
  align-items: center;
  margin: 20rpx 30rpx 0;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search_icon {
  font-size: 28rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.search_input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 72rpx;
  min-width: 0;
}

.search_clear {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
  margin-left: 10rpx;
  flex-shrink: 0;
}

/* ===== 优先级筛选 ===== */
.priority_filter {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx 0;
  gap: 16rpx;
}

.priority_filter_label {
  font-size: 24rpx;
  color: #999;
  margin-right: 4rpx;
  flex-shrink: 0;
}

.priority_filter_item {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #fff;
  border: 2rpx solid #E8E8E8;
}

.priority_filter_item.active.priority_high {
  background: #FDEDEC;
  border-color: #E74C3C;
  color: #E74C3C;
  font-weight: 500;
}

.priority_filter_item.active.priority_medium {
  background: #FEF5E7;
  border-color: #F39C12;
  color: #F39C12;
  font-weight: 500;
}

.priority_filter_item.active.priority_low {
  background: #E8F8F5;
  border-color: #6BCB77;
  color: #6BCB77;
  font-weight: 500;
}

/* ===== 筛选栏 ===== */
.filter_bar {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  margin-top: 20rpx;
  gap: 16rpx;
}

.filter_item {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border: 2rpx solid #E8E8E8;
}

.filter_item.active {
  background: #4A90E2;
  color: #fff;
  border-color: #4A90E2;
}

.clear_btn {
  margin-left: auto;
  font-size: 24rpx;
  color: #E74C3C;
  padding: 10rpx 20rpx;
}

/* ===== 待办列表 ===== */
.todo_list {
  padding: 0 30rpx;
}

.empty_state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty_icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty_text {
  font-size: 28rpx;
  color: #999;
}

/* ===== 浮动添加按钮 ===== */
.fab_btn {
  position: fixed;
  right: 50rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 226, 0.4);
  z-index: 100;
}

.fab_btn:active {
  transform: scale(0.92);
}
